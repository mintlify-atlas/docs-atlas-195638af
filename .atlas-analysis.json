  "keyFeatures": [
    "Full TypeScript support with type-safe mappings to HealthKit APIs",
    "100+ quantity types, 63 category types, and 75+ workout activity types",
    "React Hooks for declarative data fetching and subscriptions",
    "HealthKit anchor queries for efficient data synchronization",
    "Background delivery and real-time change notifications",
    "Support for workouts, correlations, electrocardiograms, and clinical data",
    "Built on react-native-nitro-modules for optimal performance"
  ],
